    "test:docs-language-lint": "node tests/docs-language-lint.test.js",
    "test:gh-safe": "node tests/gh-safe.test.js",
    "test:git-guard": "node tests/agent-git-guard.test.js",
    "test:instruction-lint": "node tests/instruction-lint.test.js",
    "test:pwa-assets": "node tests/pwa-asset-manifest.test.js",
    "test:pwa-smoke": "node tests/pwa-local-smoke.test.js",
    "test:preflight": "node tests/agent-preflight.test.js",
    "test:summary": "node tests/agent-summary.test.js",
    "test:simulation": "node tests/simulation-core.test.js",
    "test:service-worker": "node tests/service-worker.test.js",
    "verify": "npm run check && npm test && npm run instruction:lint && npm run docs:language:lint && npm run backlog:lint"
