{
  "name": "red-dune-dash",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-first endless runner and AI-agent workflow experiment.",
  "scripts": {
    "check": "node scripts/check-syntax.js",
    "setup": "node scripts/setup-hooks.js",
    "agent:advisory": "node scripts/agent-advisory.js",
    "agent:advisory:json": "node scripts/agent-advisory.js --json",
    "agent:advisory:unmatched": "node scripts/agent-advisory.js --unmatched",
    "test": "npm run test:simulation && npm run test:service-worker && npm run test:advisory",
    "test:advisory": "node tests/advisory-rules.test.js",
    "test:simulation": "node tests/simulation-core.test.js",
    "test:service-worker": "node tests/service-worker.test.js",
    "verify": "npm run check && npm test"
  }
}
