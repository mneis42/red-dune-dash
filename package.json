    "agent:advisory:unmatched": "node scripts/agent-advisory.js --unmatched",
    "agent:git": "node scripts/agent-git-guard.js",
    "agent:preflight": "node scripts/agent-preflight.js",
    "agent:preflight:json": "node scripts/agent-preflight.js --json",
    "gh:safe": "node scripts/gh-safe.js",
    "agent:summary": "node scripts/agent-summary.js",
    "test": "npm run test:simulation && npm run test:service-worker && npm run test:pwa-assets && npm run test:pwa-smoke && npm run test:advisory && npm run test:preflight && npm run test:summary && npm run test:git-guard && npm run test:gh-safe && npm run test:instruction-lint && npm run test:docs-language-lint && npm run test:backlog-lint && npm run test:backlog-branch",
    "test:advisory": "node tests/advisory-rules.test.js && node tests/agent-advisory.test.js",
    "test:backlog-branch": "node tests/backlog-to-branch.test.js",
