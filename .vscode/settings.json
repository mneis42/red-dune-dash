{
  // Makes the Autopilot permission level available in chat.
  // You still need to select it in the chat session when you want maximum autonomy.
  "chat.autopilot.enabled": true,

  // The default limit is 25 requests. A higher limit helps with longer multi-step tasks.
  "chat.agent.maxRequests": 1000,

  // Show file change summaries after chat requests so longer sessions stay easier to review.
  "chat.checkpoints.showFileChanges": true,

  // Auto-accept file edits anywhere inside this repository.
  "chat.tools.edits.autoApprove": {
    "**/*": true
  },

  // In this workspace we want the agent to move freely inside the repo.
  // Keep approvals for writes outside the workspace via blockDetectedFileWrites.
  "chat.tools.terminal.ignoreDefaultAutoApproveRules": true,
  "chat.tools.terminal.blockDetectedFileWrites": "outsideWorkspace",
  "chat.tools.terminal.autoApprove": {
    "/.*/": true
  },

  // Warn in the VS Code Git UI when someone works against the protected main branch.
  "git.branchProtection": [
    "main"
  ]
}
