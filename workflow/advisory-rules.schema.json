{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Red Dune Dash Advisory Rules",
  "type": "object",
  "required": ["version", "governance", "policyGates", "rules"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "governance": {
      "type": "object",
      "required": ["advisoryOnly", "routingAuthority", "note"],
      "additionalProperties": false,
      "properties": {
        "advisoryOnly": {
          "type": "boolean",
          "const": true
        },
        "routingAuthority": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policyGates": {
      "type": "object",
      "required": ["stages"],
      "additionalProperties": false,
      "properties": {
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/policyStage"
          }
        }
      }
    },
    "unknownFileFallback": {
      "$ref": "#/$defs/ruleLike"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ruleLike": {
      "type": "object",
      "required": [
        "id",
        "area",
        "riskTags",
        "recommendedChecks",
        "manualChecks",
        "suggestedDocs",
        "suggestedReading",
        "ciSignals"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "area": {
          "type": "string",
          "minLength": 1
        },
        "riskTags": {
          "$ref": "#/$defs/stringArray"
        },
        "recommendedChecks": {
          "$ref": "#/$defs/stringArray"
        },
        "manualChecks": {
          "$ref": "#/$defs/stringArray"
        },
        "suggestedDocs": {
          "$ref": "#/$defs/stringArray"
        },
        "suggestedReading": {
          "$ref": "#/$defs/stringArray"
        },
        "ciSignals": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "rule": {
      "allOf": [
        {
          "$ref": "#/$defs/ruleLike"
        },
        {
          "type": "object",
          "required": ["match"],
          "properties": {
            "match": {
              "$ref": "#/$defs/stringArray",
              "minItems": 1
            }
          }
        }
      ]
    },
    "policyStage": {
      "type": "object",
      "required": ["id", "label", "blocking", "status", "summary"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "id": {
                "const": "stage-3-hard-fail"
              }
            },
            "required": ["id"]
          },
          "then": {
            "required": ["candidateGates"],
            "properties": {
              "candidateGates": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/policyGate"
                }
              }
            }
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "blocking": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "candidateGates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/policyGate"
          }
        }
      }
    },
    "policyGate": {
      "type": "object",
      "required": [
        "id",
        "status",
        "confidence",
        "blocking",
        "source",
        "documentationStatusLine",
        "documentationDetailLine"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "minLength": 1
        },
        "blocking": {
          "type": "boolean"
        },
        "source": {
          "$ref": "#/$defs/stringArray"
        },
        "documentationStatusLine": {
          "type": "string",
          "minLength": 1
        },
        "documentationDetailLine": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
