{
  "version": 1,
  "governance": {
    "advisoryOnly": true,
    "routingAuthority": "AGENTS.md",
    "note": "This file is advisory only. Canonical workflow routing stays in AGENTS.md and instruction files."
  },
  "policyGates": {
    "stages": [
      {
        "id": "stage-1-advisory",
        "label": "Advisory only",
        "blocking": false,
        "status": "active",
        "summary": "Changed-file matching and workflow hints stay advisory and do not reroute canonical workflows."
      },
      {
        "id": "stage-2-warning",
        "label": "Warning mode",
        "blocking": false,
        "status": "runtime-evaluated",
        "summary": "Explicit risky runtime states surface as non-blocking warnings based on deterministic CI signals."
      },
      {
        "id": "stage-3-hard-fail",
        "label": "Selective hard fail",
        "blocking": true,
        "status": "selective-enforcement",
        "summary": "Only narrow, high-confidence policy gates should block.",
        "candidateGates": [
          {
            "id": "broken-instruction-references",
            "status": "enforced",
            "confidence": "high",
            "blocking": true,
            "source": ["npm run instruction:lint", "CI verify-linux-signals"],
            "documentationStatusLine": "Current repo status: enforced",
            "documentationDetailLine": "Enforcement path: `npm run instruction:lint` in CI"
          },
          {
            "id": "missing-mandatory-canonical-artifacts",
            "status": "enforced",
            "confidence": "high",
            "blocking": true,
            "source": ["npm run instruction:lint", "npm run backlog:lint", "CI verify-linux-signals"],
            "documentationStatusLine": "Current repo status: enforced",
            "documentationDetailLine": "Enforcement path: deterministic workflow/document lint checks such as `npm run instruction:lint` and `npm run backlog:lint`"
          },
          {
            "id": "broken-mandatory-validation-jobs",
            "status": "enforced",
            "confidence": "high",
            "blocking": true,
            "source": ["CI verify-linux-signals", "CI test"],
            "documentationStatusLine": "Current repo status: enforced",
            "documentationDetailLine": "Enforcement path: `verify-linux-signals` and the compatibility `test` gate in CI"
          },
          {
            "id": "protected-branch-violations",
            "status": "candidate-only",
            "confidence": "high",
            "blocking": false,
            "source": ["scripts/setup-hooks.js", "agent:preflight guardrail signal"],
            "documentationStatusLine": "Current repo status: candidate only, not a CI hard-fail gate",
            "documentationDetailLine": "Current coverage: local `.githooks/pre-push` protection plus `agent:preflight` guardrail visibility"
          }
        ]
      }
    ]
  },
  "unknownFileFallback": {
    "id": "fallback-unclassified",
    "area": "unclassified",
    "riskTags": ["unknown-change-surface"],
    "recommendedChecks": ["npm run check"],
    "manualChecks": [
      "review changed file manually and assign likely area",
      "cross-check relevant docs if behavior changed"
    ],
    "suggestedDocs": ["README.md", "CONTRIBUTING.md", "docs/"],
    "suggestedReading": ["AGENTS.md", "instructions/change-review.md"],
    "ciSignals": ["advisory-fallback"]
  },
  "rules": [
    {
      "id": "gameplay-core",
      "match": ["systems/**", "game-endless.js"],
      "area": "gameplay",
      "riskTags": ["game-balance", "cross-system-behavior"],
      "recommendedChecks": ["npm run check", "npm run test:simulation"],
      "manualChecks": [],
      "suggestedDocs": ["docs/", "README.md"],
      "suggestedReading": ["AGENTS.md", "instructions/feature-request.md", "instructions/bug-report.md"],
      "ciSignals": ["syntax", "simulation-tests"]
    },
    {
      "id": "pwa-offline",
      "match": ["service-worker.js", "app-assets.js", "manifest.webmanifest"],
      "area": "pwa",
      "riskTags": ["offline", "caching", "installability"],
      "recommendedChecks": ["npm run check", "npm run test:service-worker"],
      "manualChecks": [
        "run under local HTTP server",
        "offline reload smoke check",
        "installability sanity check",
        "cache update path smoke check after asset or version changes"
      ],
      "suggestedDocs": ["README.md", "docs/"],
      "suggestedReading": ["AGENTS.md", "instructions/change-review.md"],
      "ciSignals": ["syntax", "service-worker-tests"]
    },
    {
      "id": "workflow-docs",
      "match": [
        "README.md",
        "CONTRIBUTING.md",
        "AGENTS.md",
        ".github/workflows/**",
        "instructions/**",
        ".github/copilot-instructions.md",
        ".github/instructions/**"
      ],
      "area": "workflow-docs",
      "riskTags": ["process-drift", "instruction-consistency"],
      "recommendedChecks": ["npm run check"],
      "manualChecks": ["cross-read nearby docs for contradiction risk"],
      "suggestedDocs": ["README.md", "CONTRIBUTING.md", "AGENTS.md", "instructions/"],
      "suggestedReading": ["AGENTS.md"],
      "ciSignals": ["instruction-lint", "docs-language-lint", "backlog-lint", "verify-linux-signals", "cross-platform-verify", "required-check"]
    },
    {
      "id": "ui-shell",
      "match": ["index.html", "styles.css"],
      "area": "ui-shell",
      "riskTags": ["layout", "responsive-behavior"],
      "recommendedChecks": [],
      "manualChecks": ["responsive smoke check on mobile and desktop"],
      "suggestedDocs": ["README.md"],
      "suggestedReading": ["AGENTS.md", "instructions/change-review.md"],
      "ciSignals": []
    },
    {
      "id": "repo-docs",
      "match": ["docs/**", "workflow/**", "backlog/**", "workflow-ideas.md", "developer-todos.md", "todo.md"],
      "area": "workflow-docs",
      "riskTags": ["documentation-drift", "process-clarity"],
      "recommendedChecks": ["npm run check"],
      "manualChecks": ["cross-read nearby docs for contradiction risk"],
      "suggestedDocs": ["README.md", "CONTRIBUTING.md", "docs/", "instructions/"],
      "suggestedReading": ["AGENTS.md", "instructions/change-review.md"],
      "ciSignals": ["instruction-lint", "docs-language-lint", "backlog-lint", "verify-linux-signals", "cross-platform-verify", "required-check"]
    },
    {
      "id": "tooling-scripts-tests",
      "match": ["scripts/**", "tests/**", "package.json"],
      "area": "tooling",
      "riskTags": ["verification-reliability", "developer-workflow"],
      "recommendedChecks": ["npm run check", "npm test"],
      "manualChecks": ["verify command output stays actionable and non-noisy"],
      "suggestedDocs": ["README.md", "CONTRIBUTING.md", "docs/"],
      "suggestedReading": ["AGENTS.md", "instructions/change-review.md"],
      "ciSignals": ["syntax", "test-suite"]
    }
  ]
}
